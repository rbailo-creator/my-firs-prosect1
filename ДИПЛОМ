function renderBrands(filter=''){
    const box = document.getElementById('brandList');
    box.innerHTML = '';
    brandsArr.filter(b=>b.includes(filter.toUpperCase())).forEach(b=>{
        box.innerHTML+=`<div style="padding:10px;background:#f5f5f5;border-radius:10px;text-align:center;font-weight:900;cursor:pointer;" onclick="showBrandProducts('${b}')">${b}</div>`;
    });
}

document.getElementById('brandSearch').addEventListener('input', e=> renderBrands(e.target.value));

function renderProducts(list){
    const box = document.getElementById('products');
    box.innerHTML = '';
    if(list.length===0){box.innerHTML="<p>Товары отсутствуют</p>"; return;}
    list.forEach(p=>{
        const liked = wishlist.includes(p.id) ? 'liked' : '';
        const inCart = cart.includes(p.id) ? 'cart-added' : '';
        box.innerHTML += `
        <div class="card">
            <div class="card-icons">
                <i class="fa-solid fa-heart ${liked}" onclick="toggleFav(event,'${p.id}')"></i>
                <i class="fa-solid fa-cart-plus ${inCart}" onclick="toggleCart(event,'${p.id}')"></i>
            </div>
            <img src="${p.img}" onclick="openProduct('${p.id}')">
            <h3>${p.name}</h3>
            <b>${p.price}</b>
        </div>`;
    });
    updateCounters();
}
function showBrandProducts(brand){
    currentBrand = brand;
    const b = brand.trim().toUpperCase();

    if(b==="ANNY") renderProducts(annyProducts);
    else if(b==="ANOTHER FACE") renderProducts(anotherFaceProducts);
    else if(b==="ANTINOMIE") renderProducts(antinomieProducts);
    else if(b==="ANUA") renderProducts(anuaProducts);
    else if(b==="ANY BUDDY") renderProducts(anybuddyProducts);
    else if(b==="APADENT") renderProducts(apadentProducts);
    else if(b==="APAGARD") renderProducts(apagardProducts);
    else if(b==="AQUAFRESH") renderProducts(aquafreshProducts);
    else if(b==="AQUAPILING") renderProducts(aquapilingProducts); // ✅ ВАЖНО
    else if(b==="ARAVIA LABORATORIES") renderProducts(araviaLaboratoriesProducts);
    else if(b==="ARAVIA ORGANIC") renderProducts(araviaOrganicProducts);
    else renderProducts([]);
}
function openProduct(id){
    let product = allProducts.find(p=>p.id===id) || {id:id,name:"Товар отсутствует",price:"",desc:"Описание недоступно",img:"https://picsum.photos/400?random="+Math.random()};
    const liked = wishlist.includes(product.id)?'liked':'';
    const inCart = cart.includes(product.id)?'cart-added':'';
    document.getElementById('productDetail').innerHTML = `
    <div class="product-detail">
        <img src="${product.img}">
        <h2>${product.name}</h2>
        <h3>${product.price}</h3>
        <p>${product.desc}</p>
        <div style="display:flex;gap:10px;margin-top:10px;">
            <i class="fa-solid fa-heart ${liked}" onclick="toggleFav(event,'${product.id}')"></i>
            <i class="fa-solid fa-cart-plus ${inCart}" onclick="toggleCart(event,'${product.id}')"></i>
        </div>
    </div>`;
    document.getElementById('productModal').style.display='block';
}

function toggleFav(e,id){
    e.stopPropagation();
    wishlist.includes(id)?wishlist=wishlist.filter(x=>x!==id):wishlist.push(id);
    localStorage.setItem('wishlist',JSON.stringify(wishlist));
    renderCurrent();
}

function toggleCart(e,id){
    e.stopPropagation();
    cart.includes(id)?cart=cart.filter(x=>x!==id):cart.push(id);
    localStorage.setItem('cart',JSON.stringify(cart));
    renderCurrent();
}

function updateCounters(){
    document.getElementById('favCount').innerText = wishlist.length;
    document.getElementById('cartCount').innerText = cart.length;
}

function renderCurrent(){
    if(currentTab==='brands' && currentBrand){showBrandProducts(currentBrand);}
    else{
        const favCartProducts = allProducts.filter(p => wishlist.includes(p.id) || cart.includes(p.id));
        renderProducts(favCartProducts);
    }
}

function openTab(tab,el){
    currentTab = tab;
    currentBrand = '';
    document.querySelectorAll('.center-menu span').forEach(s=>s.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('brandsSection').style.display = (tab==='brands')?'block':'none';
    if(tab==='brands') renderBrands();
    else renderCurrent();
}

function openProfile(){document.getElementById('profileModal').style.display='block'}
function closeProfile(){document.getElementById('profileModal').style.display='none'}
function closeProduct(){document.getElementById('productModal').style.display='none'}

renderBrands();
openTab('brands',document.querySelector('.center-menu span.active'));
</script>
