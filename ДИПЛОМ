.modal-content{background:#fff;margin:80px auto;padding:20px;width:90%;max-width:500px;border-radius:15px;position:relative}
.close{position:absolute;top:10px;right:15px;font-size:24px;cursor:pointer}
.product-detail img{width:100%;border-radius:10px;margin-bottom:15px}
.product-detail p{white-space:pre-line;line-height:1.5;margin-top:10px;}
button{width:100%;padding:10px;background:black;color:white;border:none;border-radius:10px;margin-top:8px;cursor:pointer}
